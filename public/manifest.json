{
  "manifest_version": 3,
  "name": "Pomogator.ai",
  "version": "0.1.0",
  "description": "Анализ карточки товара на Ozon",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://www.ozon.ru/product/*"],
      "js": ["src/content/index.tsx"]
    }
  ],
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api-seller.ozon.ru/*",
    "https://www.ozon.ru/*"
  ],
  "web_accessible_resources": [
  {
    "resources": ["assets/*", "keywords_db.json"],
    "matches": ["*://www.ozon.ru/*"]
  }
]
}