# ─── Сервер ───────────────────────────────────────────────────────────────────
PORT=3000

# Поставить true только если бэкенд стоит за reverse proxy (nginx, Caddy)
# Если false/не задан — X-Forwarded-For игнорируется (защита от IP spoofing)
TRUST_PROXY=false

# ─── Ключ шифрования БД ───────────────────────────────────────────────────────
# AES-256-GCM, 32 байта в hex (64 символа)
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ВАЖНО: потеря этого ключа = потеря всех API-ключей клиентов в БД
DB_ENCRYPTION_KEY=ЗАМЕНИ_НА_64_HEX_СИМВОЛОВ

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://pomogator:pomogator@localhost:5432/pomogator

# ─── Ozon Seller API (не нужны — ключи вводятся через UI и хранятся в БД) ────
OZON_API_BASE=https://api-seller.ozon.ru
OZON_CLIENT_ID=
OZON_API_KEY=

# ─── Пороги светофора маржи ───────────────────────────────────────────────────
MARGIN_GREEN=20
MARGIN_YELLOW=10
